<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <PackageId>Microsoft.WebUI</PackageId>
    <RootNamespace>Microsoft.WebUI</RootNamespace>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReadme>README.md</PackageReadme>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)../../runtimes')">
    <None Include="$(MSBuildThisFileDirectory)../../runtimes/**/native/*"
          Pack="true"
          PackagePath="runtimes/%(RecursiveDir)%(Filename)%(Extension)"
          Visible="false" />
  </ItemGroup>
</Project>
